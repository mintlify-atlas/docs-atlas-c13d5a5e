  "keyFeatures": [
    "Game server management with Docker isolation",
    "Web-based console and file manager",
    "User and permission management with subusers",
    "Automated backups and schedules",
    "Multiple node support with load balancing",
    "RESTful API for automation",
    "Database management per server",
    "Dynamic resource allocation",
    "Two-factor authentication",
    "Activity logging and audit trails"
  ],
